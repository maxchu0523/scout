{
  "name": "scout-ai",
  "version": "0.3.0",
  "description": "Scout — a live scanner for connectable MCP servers and local AI APIs (LM Studio, Ollama). Discovers, verifies, and invokes them; like nmap for MCP.",
  "type": "module",
  "bin": {
    "scout": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "check": "npm run lint && npm run typecheck && npm test",
    "setup-hooks": "git config core.hooksPath githooks",
    "prepare": "git config core.hooksPath githooks || true",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "scanner",
    "cli",
    "discovery",
    "ai",
    "llm",
    "lm-studio",
    "ollama"
  ],
  "license": "MIT",
  "author": "https://github.com/maxchu0523",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxchu0523/scout.git"
  },
  "homepage": "https://github.com/maxchu0523/scout#readme",
  "bugs": {
    "url": "https://github.com/maxchu0523/scout/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
