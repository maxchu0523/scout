{
  "name": "scout-mcp",
  "version": "0.2.0",
  "description": "Scout — a live MCP scanner. Discovers and verifies connectable MCP servers, like nmap for MCP.",
  "type": "module",
  "bin": {
    "scout": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "check": "npm run lint && npm run typecheck && npm test",
    "prepare": "git config core.hooksPath githooks"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "scanner",
    "cli",
    "discovery"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
